<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appSettings>
  </appSettings>
  <system.web>
   <customErrors mode="Off" />
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8"/>
  </system.web>
  <runtime>
  </runtime>
  <system.diagnostics>
    <switches>
      <add name="TraceLevelSwitch" value="Error" />
    </switches>
    <trace autoflush="true" indentsize="4">
      <listeners>
        <add name="agsProxyLogListener" type="System.Diagnostics.TextWriterTraceListener" initializeData=".\app.log" />
        <remove name="Default" />
      </listeners>
    </trace>
  </system.diagnostics>
</configuration>
